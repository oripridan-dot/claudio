{
  "name": "claudio-core-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup-wasm": "mkdir -p public/wasm && cp node_modules/onnxruntime-web/dist/*.wasm public/wasm/",
    "dev": "npm run setup-wasm && vite",
    "dev:teach": "npm run setup-wasm && VITE_APP_ENV=teaching vite",
    "build": "npm run setup-wasm && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "onnxruntime-web": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
